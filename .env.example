# ── Copy this to .env and fill in your values ────────────────────────────────

# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Database  (default = SQLite dev db, swap URL for PostgreSQL in prod)
DATABASE_URL=sqlite+aiosqlite:///./job_assistant.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/job_assistant

# App
SECRET_KEY=change-me-in-production
ENVIRONMENT=development          # development | production

# Job Scraping proxy (optional, helps avoid rate-limiting)
PROXY_URL=

# Output directory for generated files
OUTPUT_DIR=./outputs

# Match threshold (0-100)  – only show jobs above this score
MATCH_THRESHOLD=65
